{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.user.v1",
  "title": "Personal Pipeline direct-route profile (pipeline.user.yaml, Phase 2.6 P3)",
  "description": "Structure-only validation for the one editable v1 direct-route source. setup.mjs owns the compiler; generated Claude modelRouting and provider-neutral runnerRoutes are projections, not second authorities.",
  "type": "object",
  "required": ["schema", "setup", "language", "agent_runtime", "routing", "autonomy", "gates"],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "string", "enum": ["pipeline.user.v1"] },
    "setup": {
      "type": "object",
      "required": ["intent"],
      "additionalProperties": false,
      "properties": {
        "intent": { "type": "string", "enum": ["unconfigured", "consumer", "maintainer"] }
      },
      "description": "Public setup intent only. Personal coordinates and credentials stay out of this schema and all generated Public-Core projections."
    },
    "language": {
      "type": "object",
      "required": ["human_facing", "agent_facing"],
      "additionalProperties": false,
      "properties": {
        "human_facing": { "type": "string", "enum": ["de", "en"] },
        "agent_facing": { "type": "string", "enum": ["de", "en"] }
      }
    },
    "agent_runtime": { "type": "string", "enum": ["claude-code", "other"] },
    "routing": {
      "type": "object",
      "required": ["worktypes", "duties"],
      "additionalProperties": false,
      "properties": {
        "worktypes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["design_phase", "execution_phase", "advisor"],
            "additionalProperties": false,
            "properties": {
              "design_phase": {
                "type": "object", "required": ["runner", "selector", "effort", "unavailability", "evidenceRequirement"], "additionalProperties": false,
                "properties": {
                  "runner": { "type": "string", "enum": ["claude", "codex"] },
                  "selector": { "type": "object", "required": ["kind", "value"], "additionalProperties": false, "properties": { "kind": { "type": "string", "enum": ["alias", "model-id"] }, "value": { "type": "string" } } },
                  "effort": { "type": "string", "enum": ["low", "medium", "high", "xhigh", "max", "not-applicable"] },
                  "unavailability": { "type": "string", "enum": ["defer", "mapped-fallback"] },
                  "evidenceRequirement": { "type": "string", "enum": ["dispatch-receipt"] }
                }
              },
              "execution_phase": {
                "type": "object", "required": ["runner", "selector", "effort", "unavailability", "evidenceRequirement"], "additionalProperties": false,
                "properties": {
                  "runner": { "type": "string", "enum": ["claude", "codex"] },
                  "selector": { "type": "object", "required": ["kind", "value"], "additionalProperties": false, "properties": { "kind": { "type": "string", "enum": ["alias", "model-id"] }, "value": { "type": "string" } } },
                  "effort": { "type": "string", "enum": ["low", "medium", "high", "xhigh", "max", "not-applicable"] },
                  "unavailability": { "type": "string", "enum": ["defer", "mapped-fallback"] },
                  "evidenceRequirement": { "type": "string", "enum": ["dispatch-receipt"] }
                }
              },
              "advisor": {}
            }
          }
        },
        "duties": {
          "type": "object",
          "additionalProperties": {
            "type": "object", "required": ["runner", "selector", "effort", "unavailability", "evidenceRequirement"], "additionalProperties": false,
            "properties": {
              "runner": { "type": "string", "enum": ["claude", "codex"] },
              "selector": { "type": "object", "required": ["kind", "value"], "additionalProperties": false, "properties": { "kind": { "type": "string", "enum": ["alias", "model-id"] }, "value": { "type": "string" } } },
              "effort": { "type": "string", "enum": ["low", "medium", "high", "xhigh", "max", "not-applicable"] },
              "unavailability": { "type": "string", "enum": ["defer", "mapped-fallback"] },
              "evidenceRequirement": { "type": "string", "enum": ["dispatch-receipt"] }
            }
          }
        }
      }
    },
    "autonomy": {
      "type": "object",
      "required": ["push_policy", "branch_model", "wip_limit"],
      "additionalProperties": false,
      "properties": {
        "push_policy": { "type": "string", "enum": ["gated", "standing-approved"] },
        "branch_model": { "type": "string", "enum": ["feature-branch", "direct-main"] },
        "wip_limit": { "type": "number" }
      }
    },
    "gates": {
      "type": "object",
      "required": ["dev_plan", "push", "security", "claude_md_max_lines"],
      "additionalProperties": false,
      "properties": {
        "dev_plan": { "type": "string", "enum": ["blocking", "warn", "off"] },
        "push": { "type": "string", "enum": ["blocking", "warn", "off"] },
        "security": { "type": "string", "enum": ["blocking", "warn", "off"] },
        "claude_md_max_lines": { "type": "number" }
      }
    },
    "release": {
      "type": "object",
      "description": "OPTIONAL SDLC Release/Promotion phase config (ADR-0033/0034), mirrored structure-only from plugins/pipeline-core/scripts/pipeline-manifest.schema.json's `release` property block (same schema-lite validator, plugins/pipeline-core/lib/schema-lite.mjs). Absent = zero behavior change (anti-bloat) -- deliberately NOT in this file's root `required` list.",
      "additionalProperties": false,
      "properties": {
        "environments": {
          "type": "object",
          "description": "Keys are arbitrary environment names (test, prod, ...); every value validated against the environment shape below.",
          "additionalProperties": {
            "type": "object",
            "required": ["adapter", "healthcheck", "rollback"],
            "additionalProperties": false,
            "properties": {
              "adapter": { "type": "string", "description": "Must reference a declared release.adapters key (semantic integrity check, manifest.mjs checkReleaseIntegrity)." },
              "target": { "type": "string", "description": "OPTIONAL deploy-destination id." },
              "healthcheck": { "type": "string" },
              "rollback": { "type": "string", "description": "Procedure ref, or the literal \"none-irreversible\" -- mandatory per environment." },
              "promotion": { "type": "string", "enum": ["human-gate"], "description": "OPTIONAL; presence = this env carries the promote human-gate." }
            }
          }
        },
        "adapters": {
          "type": "object",
          "description": "Keys are arbitrary adapter names (vercel-preview, vercel-prod, ...); every value validated against the adapter shape below.",
          "additionalProperties": {
            "type": "object",
            "required": ["executor", "credentials"],
            "additionalProperties": false,
            "properties": {
              "executor": { "type": "string", "enum": ["ci", "local"] },
              "trigger": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "refs": { "type": "array", "items": { "type": "string" } }
                }
              },
              "command": { "type": "string" },
              "deploy": { "type": "string" },
              "credentials": { "type": "string", "enum": ["oidc", "ci-secret", "external"] }
            }
          }
        }
      }
    }
  }
}
