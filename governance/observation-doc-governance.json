{
  "schema": "pipeline.observation-doc-governance.v1",
  "canonicalIssue": {
    "scope": "repository-global",
    "branchIndependent": true,
    "initialFormLabels": [
      "kind:observation",
      "triage:needs-review"
    ],
    "controlledAreaLabelAllowed": true,
    "securityRoute": "private-vulnerability-reporting"
  },
  "lifecycle": {
    "states": [
      "observation",
      "triage",
      "confirmed",
      "known-error",
      "backlog-link"
    ],
    "transitions": {
      "observation": [
        "triage"
      ],
      "triage": [
        "confirmed"
      ],
      "confirmed": [
        "known-error",
        "backlog-link"
      ],
      "known-error": [
        "backlog-link"
      ],
      "backlog-link": []
    }
  },
  "backlog": {
    "promotion": "explicit-after-triage",
    "requiresStablePublicBranch": true,
    "reciprocalLinksRequired": true,
    "automaticPromotion": false
  },
  "privateOverlay": {
    "allowedContent": [
      "private-deltas",
      "public-issue-links",
      "public-backlog-links"
    ],
    "mayReplacePublicIssue": false,
    "mayDuplicatePublicObservation": false
  },
  "documentation": {
    "audiences": [
      "public-user",
      "maintainer",
      "machine"
    ],
    "lifecycles": [
      "maintained",
      "normative-record",
      "compatibility-redirect",
      "review-candidate"
    ],
    "inventory": [
      {
        "audience": "public-user",
        "lifecycle": "maintained",
        "paths": [
          "docs/README.md",
          "docs/deploy/README.md",
          "docs/design/README.md",
          "docs/design/design-facilitator-prompt.md",
          "docs/design/export-template.md",
          "docs/observation-intake.md",
          "docs/operating-model.md",
          "docs/runtime-boundary.md"
        ]
      },
      {
        "audience": "public-user",
        "lifecycle": "compatibility-redirect",
        "paths": [
          "docs/migration.md",
          "docs/overview.md",
          "docs/usage.md"
        ]
      },
      {
        "audience": "public-user",
        "lifecycle": "review-candidate",
        "paths": [
          "docs/design-decisions.md"
        ]
      },
      {
