{
  "$comment": "Project calibration for the Agent-Pipeline ritual skills (schema: operating-model §8; consumed by pipeline-start step 3 and close-block step 0). Copy to <project>/.claude/pipeline.json, adapt, COMMIT. Keys starting with '$' are documentation and ignored by the skills. This is a FILLED example for the fictional project 'acme-notes' (a small Next.js notes app) - every value below is example data, replace it. Project DENIES do NOT live here: they live in the committed .claude/settings.json and/or .claude/guard-config.json.",
  "project": "acme-notes",
  "verify": "pnpm verify",
  "$verify": "THE one gate command: format -> lint -> typecheck -> tests -> build wrapped in a single script. Stop hook, goldfish delivery and CI must call this same command.",
  "autonomy": "interactive",
  "$autonomy": "Autonomy level for this project, e.g. interactive | remote | night-branch-only.",
  "branchModel": "direct-push+staging",
  "$branchModel": "e.g. direct-push+staging | pr-flow.",
  "verification": "tests+browser",
  "$verification": "Human verification form, e.g. tests+browser | live-devices | pie-human.",
  "wipLimit": 1,
  "$wipLimit": "Max open human-gate processes in this project.",
  "rollback": "git revert <merge-commit-sha> on main; re-run verify",
  "$rollback": "Per-project rollback procedure: how to revert a bad merge in this project. Required whenever a merge proceeds while a mandatory human verification is still pending: documents HOW to step back to the pre-merge state in an emergency, paired with the rollback anchor (pre-merge tag/commit ref recorded in the handover file).",
  "worktree": "on-write",
  "$worktree": "Worktree mode for writing goldfish tasks: on-write | off | always - validate per project; editor gates may be fail-open in worktrees depending on project setup.",
  "stakes": "medium",
  "$stakes": "Project stakes rating: low | medium | high. Drives discipline position on the vibe<->engineering spectrum.",
  "constraints": [
    "No breaking API change without an ADR",
    "Do not downgrade the Next.js major version (constraint #3 - do not roll back)",
    "Note exports must stay streaming - no full in-memory buffering"
  ],
  "$constraints": "Project rules and 'do not roll back' items; goldfish briefings quote them, the Critic uses them as measuring stick.",
  "claudeMdMaxLines": 220,
  "$claudeMdMaxLines": "Hard length gate for the project CLAUDE.md. Checked in close-block step 4.",
  "riskZones": ["app/api/**", "prisma/**", ".claude/**"],
  "$riskZones": "Paths whose diffs raise the risk class in triage (operating-model §4.2); .claude/** additionally marks guardrail surface.",
  "handover": "docs/state.md",
  "$handover": "Optional; the project's single handover/state file. Default when absent: docs/state.md (operating-model §6 convention).",
  "$driftThreshold": "Optional override of the bootstrap handover-drift check (session-bootstrap.md Step 4, #27). Default (used when this key is absent): warn when the repo's last commit is newer than the handover state AND the delta since then contains at least one non-docs commit.",
  "ritualExtensions": {
    "$comment": "Named extension points let a project append ritual steps WITHOUT forking the central skills (goal: extendable, fork-free). Entry semantics (defined in close-block SKILL.md): entries run in array order; an entry is invoked as a SKILL only when it starts with '/' OR the whole entry matches ^[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$ (no whitespace, exactly one namespace colon, e.g. 'pipeline-core:pipeline-start'); anything else runs as a shell command from the project root - so 'pnpm run sync:changelog' or 'docker run image:tag' are shell, not skills. A failing entry stops the ritual with an explicit report. Points defined today by close-block: close.pre (after calibration read, before honesty/verify/drift checks) and close.post (after handover/telemetry/retro, before the final commit). Future ritual skills define their own points (e.g. newBlockReview.post) - unknown points are ignored by skills that do not define them.",
    "close.pre": ["pnpm run sync-changelog"],
    "close.post": ["/acme-db-hygiene"]
  }
}
