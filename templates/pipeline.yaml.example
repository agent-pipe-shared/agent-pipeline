# pipeline.yaml.example -- canonical, fully-commented example of the OPTIONAL declarative
# pipeline manifest (schema id: pipeline.manifest.v0). Use this as a reference for a
# DIRECTLY AUTHORED manifest only. Compiler-managed installs author pipeline.user.yaml and
# let setup.mjs regenerate .claude/pipeline.yaml; do not mix the two ownership modes. Every
# top-level section is optional -- an
# absent manifest is a fully supported "not opted in yet" state, byte-identical to today's
# non-manifest behavior (plugins/pipeline-core/lib/manifest.mjs: loadManifest() returns
# status "absent", harness/scripts/validate-manifest.mjs exits 0 printing
# "Manifest not active (optional)").
#
# GRAMMAR NOTE: this file must parse with the yaml-lite strict subset
# (plugins/pipeline-core/lib/yaml-lite.mjs) -- only the constructs used below are
# supported: block maps/lists with 2-space indent per nesting level, quoted or bare
# scalars, bool/int coercion, `#` comments, and the empty flow literals `[]`/`{}`. NO
# anchors/aliases/tags, NO literal/folded block scalars (`|`/`>`), NO non-empty flow
# collections (`[1, 2]`, `{a: 1}`). Validate any edit against this repo's copy of the
# rules with:
#   node harness/scripts/validate-manifest.mjs <path-to-your-pipeline.yaml>

schema: pipeline.manifest.v0

# Phases this pipeline can run, in declaration order. `enabled: false` removes a phase
# from every profile without deleting its declaration (keep the entry, flip the flag).
# `condition` is optional; grammar: always | never | <flag> | !<flag>, where <flag> must
# name a key declared under `flags:` near the bottom of this file.
phases:
  - name: design
    enabled: true
  - name: implementation
    enabled: true
  - name: security-scan
    enabled: true
  - name: ui-design
    enabled: true
    condition: has_ui

# Gates: one entry per named checkpoint (gate names are free-form, not tied to a phase
# name above -- a gate is a control point AROUND phases, not a phase itself).
#   mode:     blocking | warn | off (QG-06-revision rationale -- a manifest mode is
#             documented project calibration, never silent decay):
#               blocking -- violations exit 2 (hard-fail, gate stops the pipeline)
#               warn     -- violations exit 1, reported but never block
#               off      -- gate disabled/no-op (must carry a reasoned comment --
#                           "off" is a deliberate, visible choice)
#   type:     human | automated
#   approval: required | standing-approved (optional; only meaningful on a human gate
#             that is pre-approved to proceed WITHOUT a live human touch every time --
#             see ADR-0017 for the standing-approval precedent this
#             mirrors).
#   exemptPaths: optional list of path-prefix strings, additive-only exemptions on top
#             of a gate's built-in defaults (e.g. dev-plan's docs/specs/.claude/backlog
#             prefixes) -- never more restrictive, only ever widens what a gate allows.
gates:
  dev-plan:
    mode: blocking
    type: human
    # exemptPaths:
    #   - scratch/
  push:
    mode: blocking
    type: human
    approval: standing-approved
  security:
    mode: blocking
    type: automated

# Configuration for the security-scan phase.
security:
  thresholds:
    block_on:
      - critical
      - high
  scanners:
    gitleaks:
      enabled: true
    osv-scanner:
      enabled: true
    semgrep:
      enabled: true
      rules_dir: governance/examples/policies/semgrep

# Example of a full generated Claude routing projection. In a real project, setup.mjs
# compiles this matrix from routing-authority.json, runner-mappings.json, and
# pipeline.user.yaml; do not maintain it as an independent policy source.
modelRouting:
  elephant_design_design:
    model: opus
    effort: high
  elephant_design_execution:
    model: opus
    effort: high
  elephant_feature_design:
    model: opus
    effort: high
  elephant_feature_execution:
    model: sonnet-5
    effort: high
  advisor_feature:
    model: opus
    effort: not-applicable
  elephant_mini_design:
    model: sonnet-5
    effort: high
  elephant_mini_execution:
    model: sonnet-5
    effort: high
  advisor_mini:
    model: opus
    effort: not-applicable
  goldfish:
    model: sonnet-5
    effort: medium
  goldfish_mechanic:
    model: sonnet-5
    effort: low
  goldfish_deep:
    model: sonnet-5
    effort: xhigh
  critic:
    model: sonnet-5
    effort: max

# Profiles bundle a phase subset by name. `active` selects which profile currently
# applies; every other key here is a profile name whose `phases` list must only name
# phases declared under `phases:` above (checked by manifest.mjs, not by the schema).
profiles:
  active: full-sdlc
  quick:
    phases:
      - implementation
  full-sdlc:
    phases:
      - design
      - implementation
      - security-scan
      - ui-design

# Governance layer: where the advisory guidelines and the enforcing policies live, and
# whether each side is currently advisory-only or actually enforcing.
governance:
  guidelines_path: governance/examples/guidelines
  policies_path: governance/examples/policies
  mode:
    guidelines: advisory
    policies: enforcing

# Feature flags referenced by phases[].condition above. Keys are free-form flag names;
# every value must be a boolean.
flags:
  has_ui: false

# Release/Promotion phase (OPTIONAL SDLC tail phase, ADR-0033/0034). Declaring a
# `release` section here opts a project into the test->prod promotion phase (adapter-based
# deploy, mandatory per-env health check + rollback procedure, an optional promote:prod human
# gate, and -- where a central deploy-policy.yaml exists at governance.policies_path above --
# precedence checking against it, see plugins/pipeline-core/lib/manifest.mjs
# checkReleaseIntegrity/checkDeployPrecedence). Absent (the default, as in this template) =
# zero new behavior (anti-bloat). Left commented out here on purpose -- uncomment and adapt
# only for a project that actually deploys. Two-environment vercel-preview/vercel-prod worked
# shape:
#
# release:
#   environments:
#     test:
#       adapter: vercel-preview       # must reference a declared adapter (integrity check)
#       healthcheck: <command-or-workflow-ref>
#       rollback: <procedure-ref>     # MANDATORY per environment
#     prod:
#       adapter: vercel-prod
#       healthcheck: <command-or-workflow-ref>
#       rollback: <procedure-ref>
#       promotion: human-gate         # fixed value in v1
#   adapters:
#     vercel-preview:
#       executor: ci
#       deploy: <workflow-ref>        # test-env deploy (merge-triggered), no release refs
#       credentials: oidc
#     vercel-prod:
#       executor: ci                  # ci | local -- the swappable driver
#       trigger:
#         refs:
#           - refs/tags/v*            # ci executor: release-triggering ref patterns
#       deploy: <workflow-ref>        # local executor: a command reference instead
#       credentials: oidc             # oidc | ci-secret | external -- never inline values
