{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.sentinel-backlog-recovery.v1",
  "type": "object",
  "required": ["schema", "source", "recoveredAt", "items"],
  "properties": {
    "schema": { "const": "pipeline.sentinel-backlog-recovery.v1" },
    "source": { "type": "string", "minLength": 1 },
    "recoveredAt": { "type": "string", "format": "date" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
          "status": { "enum": ["open", "in_progress"] },
          "type": { "enum": ["workflow-improvement", "tooling-radar", "defect", "idea"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
