{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.document-renderer-request.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "requestId", "repoFingerprint", "classId", "bindingId", "event", "candidateCommit", "candidateTree", "dataPath", "dataSha256", "templatePath", "templateSha256", "outputMode", "deadlineAt"],
  "properties": {
    "schema": { "const": "pipeline.document-renderer-request.v1" },
    "requestId": { "type": "string", "pattern": "^drq_[a-z2-7]{25}[aeimquy4]$" },
    "repoFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "classId": { "enum": ["authorization", "operations", "emergency", "privacy"] },
    "bindingId": { "type": "string", "pattern": "^dh_[a-z2-7]{25}[aeimquy4]$" },
    "event": { "enum": ["design-impact", "verify", "close"] },
    "candidateCommit": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "candidateTree": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "dataPath": { "type": "string", "minLength": 1 },
    "dataSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "templatePath": { "type": "string", "minLength": 1 },
    "templateSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "outputMode": { "const": "framed-stdout-v1" },
    "deadlineAt": { "type": "string", "format": "date-time" }
  }
}
