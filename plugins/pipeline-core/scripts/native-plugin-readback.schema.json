{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.btm-d2-native-readback.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "transactionId", "revision", "priorStateSha256", "phase", "provider", "pluginId", "sourceOid", "loadedRootKind", "manifest", "loadedChain", "observations", "reason", "observedManifest", "observedChain", "receiptDigest"],
  "properties": {
    "schema": { "const": "pipeline.btm-d2-native-readback.v1" },
    "transactionId": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,80}$" },
    "revision": { "type": "integer", "minimum": 0 },
    "priorStateSha256": { "$ref": "#/$defs/nullableSha256" },
    "phase": { "enum": ["prepared", "update-observed", "reload-observed", "trust-observed", "fresh-session-observed", "verified", "blocked"] },
    "provider": { "enum": ["claude", "codex"] },
    "pluginId": { "const": "pipeline-core" },
    "sourceOid": { "$ref": "#/$defs/oid" },
    "loadedRootKind": { "enum": ["claude-project-scope", "codex-provider-cache"] },
    "manifest": { "$ref": "#/$defs/manifest" },
    "loadedChain": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/expectedChain" } },
    "observations": { "type": "array", "maxItems": 4, "items": { "$ref": "#/$defs/observation" } },
    "reason": { "type": ["string", "null"] },
    "observedManifest": { "oneOf": [{ "$ref": "#/$defs/observedChain" }, { "type": "null" }] },
    "observedChain": { "oneOf": [{ "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/observedChain" } }, { "type": "null" }] },
    "receiptDigest": { "$ref": "#/$defs/nullableSha256" }
  },
  "$defs": {
    "oid": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nullableSha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "manifest": { "type": "object", "additionalProperties": false, "required": ["relativePath", "name", "version", "digest"], "properties": { "relativePath": { "enum": [".claude-plugin/plugin.json", ".codex-plugin/plugin.json"] }, "name": { "const": "pipeline-core" }, "version": { "type": "string", "minLength": 1 }, "digest": { "$ref": "#/$defs/sha256" } } },
    "expectedChain": { "type": "object", "additionalProperties": false, "required": ["relativePath", "expectedDigest"], "properties": { "relativePath": { "type": "string", "minLength": 1 }, "expectedDigest": { "$ref": "#/$defs/sha256" } } },
    "observedChain": { "type": "object", "additionalProperties": false, "required": ["relativePath", "digest"], "properties": { "relativePath": { "type": "string", "minLength": 1 }, "digest": { "$ref": "#/$defs/sha256" } } },
    "observation": { "type": "object", "additionalProperties": false, "required": ["phase", "status", "evidenceDigest", "observedAt"], "properties": { "phase": { "enum": ["update-observed", "reload-observed", "trust-observed", "fresh-session-observed"] }, "status": { "const": "observed" }, "evidenceDigest": { "$ref": "#/$defs/sha256" }, "observedAt": { "type": "integer" } } }
  }
}
