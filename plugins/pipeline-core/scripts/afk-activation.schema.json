{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.afk-activation.v1",
  "title": "AFK activation authority receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "activationId",
    "attributedBy",
    "attributionBoundary",
    "activatedAt",
    "expiresAt",
    "lastWallClock",
    "finalGate",
    "feature",
    "base",
    "statePreimageSha256",
    "authority",
    "packages",
    "pathAllowlist",
    "surface",
    "budgets",
    "deny",
    "worktree",
    "receiptSha256"
  ],
  "properties": {
    "schema": { "const": "pipeline.afk-activation.v1" },
    "activationId": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
    "attributedBy": { "type": "string", "minLength": 1, "maxLength": 256 },
    "attributionBoundary": { "const": "process-attribution-only; not-authentication-or-product-approval" },
    "activatedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "lastWallClock": { "type": "string", "format": "date-time" },
    "finalGate": { "const": "po-review-required" },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ref"],
      "properties": {
        "id": { "$ref": "#/$defs/safeId" },
        "ref": { "type": "string", "pattern": "^refs/heads/(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$" }
      }
    },
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "tree", "objectFormat"],
      "properties": {
        "commit": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
        "tree": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
        "objectFormat": { "enum": ["sha1", "sha256"] }
      }
    },
    "statePreimageSha256": { "$ref": "#/$defs/sha256" },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prd", "spec", "courseBrief"],
      "properties": {
        "prd": { "$ref": "#/$defs/artifact" },
        "spec": { "$ref": "#/$defs/artifact" },
        "courseBrief": { "$ref": "#/$defs/artifact" }
      }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/safeId" }
    },
    "pathAllowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read", "write"],
      "properties": {
        "read": { "$ref": "#/$defs/pathList" },
        "write": { "$ref": "#/$defs/pathList" }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "adapterId", "adapterSha256", "tools", "toolInventorySha256"],
      "properties": {
        "provider": { "const": "claude" },
        "adapterId": { "const": "pipeline.afk-claude-worker.v1" },
        "adapterSha256": { "$ref": "#/$defs/sha256" },
        "tools": {
          "type": "array",
          "prefixItems": [
            { "const": "Glob" },
            { "const": "Grep" },
            { "const": "Read" }
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "toolInventorySha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries", "files", "bytes"],
      "properties": {
        "entries": { "type": "integer", "minimum": 1 },
        "files": { "type": "integer", "minimum": 1 },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "deny": {
      "type": "array",
      "prefixItems": [
        { "const": "child-process" },
        { "const": "general-command" },
        { "const": "merge" },
        { "const": "network-effect" },
        { "const": "package-install" },
        { "const": "push" },
        { "const": "release" },
        { "const": "remote-write" },
        { "const": "secret-request" },
        { "const": "tag" }
      ],
      "items": false,
      "minItems": 10,
      "maxItems": 10
    },
    "worktree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inventorySha256", "count", "featureRefCheckouts", "head", "indexTree", "worktreeTree", "detached", "clean"],
      "properties": {
        "inventorySha256": { "$ref": "#/$defs/sha256" },
        "count": { "type": "integer", "minimum": 1 },
        "featureRefCheckouts": { "const": 0 },
        "head": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
        "indexTree": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
        "worktreeTree": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
        "detached": { "const": true },
        "clean": { "const": true }
      }
    },
    "receiptSha256": { "$ref": "#/$defs/sha256" }
  },
  "allOf": [
    {
      "if": { "properties": { "base": { "properties": { "objectFormat": { "const": "sha1" } } } } },
      "then": {
        "properties": {
          "base": {
            "properties": {
              "commit": { "pattern": "^[a-f0-9]{40}$" },
              "tree": { "pattern": "^[a-f0-9]{40}$" }
            }
          },
          "worktree": {
            "properties": {
              "head": { "pattern": "^[a-f0-9]{40}$" },
              "indexTree": { "pattern": "^[a-f0-9]{40}$" },
              "worktreeTree": { "pattern": "^[a-f0-9]{40}$" }
            }
          }
        }
      },
      "else": {
        "properties": {
          "base": {
            "properties": {
              "commit": { "pattern": "^[a-f0-9]{64}$" },
              "tree": { "pattern": "^[a-f0-9]{64}$" }
            }
          },
          "worktree": {
            "properties": {
              "head": { "pattern": "^[a-f0-9]{64}$" },
              "indexTree": { "pattern": "^[a-f0-9]{64}$" },
              "worktreeTree": { "pattern": "^[a-f0-9]{64}$" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "safeId": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._-]{0,126}[A-Za-z0-9])?$" },
    "repoPath": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.[gG][iI][tT](?:/|$))(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[^\\u0000\\r\\n]+$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/repoPath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "pathList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repoPath" }
    }
  }
}
