{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.document-hooks-policy.v1",
  "title": "Regulated document hooks repository Policy",
  "description": "Closed public Policy discovered only as document-hooks.yaml below governance.policies_path. Binding identifiers are opaque; private trigger, adapter, content, and organisation data are intentionally outside this contract.",
  "type": "object",
  "required": ["schema", "classes"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["pipeline.document-hooks-policy.v1"]
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["classId", "bindingId", "mode", "events"],
        "additionalProperties": false,
        "properties": {
          "classId": {
            "type": "string",
            "enum": ["authorization", "operations", "emergency", "privacy"]
          },
          "bindingId": {
            "type": "string",
            "pattern": "^dh_[a-z2-7]{25}[aeimquy4]$"
          },
          "mode": {
            "type": "string",
            "enum": ["advisory", "mandatory"]
          },
          "events": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["design-impact", "verify", "close"]
            }
          }
        }
      }
    }
  }
}
