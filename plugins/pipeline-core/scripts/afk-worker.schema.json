{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.afk-worker.v1",
  "title": "Closed AFK capability-worker request or result",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/result" }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "oid": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
    "safeId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*(?:^|/)\\.git(?:/|$))[^\\u0000]+$"
    },
    "current": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "tree", "objectFormat"],
      "properties": {
        "commit": { "$ref": "#/$defs/oid" },
        "tree": { "$ref": "#/$defs/oid" },
        "objectFormat": { "enum": ["sha1", "sha256"] }
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mode", "blobOid", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/repoPath" },
        "mode": { "enum": ["100644", "100755"] },
        "blobOid": { "$ref": "#/$defs/oid" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema", "activationId", "activationReceiptSha256", "sequence", "dispatchId",
        "attempt", "privateRef", "current", "prior", "readSnapshot", "pathAllowlist",
        "budgets", "adapter", "requestSha256"
      ],
      "properties": {
        "schema": { "const": "pipeline.afk-worker-request.v1" },
        "activationId": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
        "activationReceiptSha256": { "$ref": "#/$defs/sha256" },
        "sequence": { "type": "integer", "minimum": 1 },
        "dispatchId": { "$ref": "#/$defs/safeId" },
        "attempt": { "type": "integer", "minimum": 1 },
        "privateRef": { "type": "string", "pattern": "^refs/agent-pipeline/afk/[0-9a-f]{32}$" },
        "current": { "$ref": "#/$defs/current" },
        "prior": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["entryId", "resultSha256"],
              "properties": {
                "entryId": { "$ref": "#/$defs/safeId" },
                "resultSha256": { "$ref": "#/$defs/sha256" }
              }
            }
          ]
        },
        "readSnapshot": { "type": "array", "items": { "$ref": "#/$defs/snapshot" } },
        "pathAllowlist": {
          "type": "object",
          "additionalProperties": false,
          "required": ["read", "write"],
          "properties": {
            "read": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/repoPath" } },
            "write": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/repoPath" } }
          }
        },
        "budgets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["files", "bytes"],
          "properties": {
            "files": { "type": "integer", "minimum": 1 },
            "bytes": { "type": "integer", "minimum": 1 }
          }
        },
        "adapter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "id", "sha256", "tools"],
          "properties": {
            "provider": { "const": "claude" },
            "id": { "const": "pipeline.afk-claude-worker.v1" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "tools": {
              "type": "array",
              "prefixItems": [
                { "const": "Glob" },
                { "const": "Grep" },
                { "const": "Read" }
              ],
              "minItems": 3,
              "maxItems": 3
            }
          }
        },
        "requestSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "reason", "effect", "rejectionConsequence", "recommended"],
      "properties": {
        "id": { "$ref": "#/$defs/safeId" },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "effect": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "rejectionConsequence": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "recommended": { "type": "boolean" }
      }
    },
    "write": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation", "path", "baseMode", "baseBlobOid", "resultMode",
        "resultContentBase64", "resultSha256"
      ],
      "properties": {
        "operation": { "enum": ["put", "delete"] },
        "path": { "$ref": "#/$defs/repoPath" },
        "baseMode": { "type": ["string", "null"], "enum": ["100644", "100755", null] },
        "baseBlobOid": { "oneOf": [{ "$ref": "#/$defs/oid" }, { "type": "null" }] },
        "resultMode": { "type": ["string", "null"], "enum": ["100644", "100755", null] },
        "resultContentBase64": { "type": ["string", "null"] },
        "resultSha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema", "activationId", "requestSha256", "sequence", "dispatchId", "attempt",
        "current", "finding", "options", "recommendation", "provisionalChoice", "writes",
        "resultSha256"
      ],
      "properties": {
        "schema": { "const": "pipeline.afk-worker-result.v1" },
        "activationId": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
        "requestSha256": { "$ref": "#/$defs/sha256" },
        "sequence": { "type": "integer", "minimum": 1 },
        "dispatchId": { "$ref": "#/$defs/safeId" },
        "attempt": { "type": "integer", "minimum": 1 },
        "current": { "$ref": "#/$defs/current" },
        "finding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "failureSignature"],
          "properties": {
            "id": { "$ref": "#/$defs/safeId" },
            "failureSignature": { "$ref": "#/$defs/sha256" }
          }
        },
        "options": { "type": "array", "minItems": 2, "maxItems": 8, "items": { "$ref": "#/$defs/option" } },
        "recommendation": { "$ref": "#/$defs/safeId" },
        "provisionalChoice": { "$ref": "#/$defs/safeId" },
        "writes": { "type": "array", "items": { "$ref": "#/$defs/write" } },
        "resultSha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
