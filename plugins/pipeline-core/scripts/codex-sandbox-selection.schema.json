{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.codex-sandbox-selection.v1",
  "title": "Closed Codex sandbox prelaunch selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "selectionId", "repoFingerprint", "duty", "dispatch", "toolchain", "host", "profile", "preflight", "compatibilityReceiptSha256", "assurance", "status", "failureClass", "observedAt"],
  "properties": {
    "schema": { "const": "pipeline.codex-sandbox-selection.v1" },
    "selectionId": { "type": "string", "pattern": "^css_[a-z2-7]{25}[aeimquy4]$" },
    "repoFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "duty": { "enum": ["advisory", "readiness", "critic"] },
    "dispatch": { "$ref": "#/$defs/dispatch" },
    "toolchain": { "$ref": "#/$defs/toolchain" },
    "host": { "$ref": "#/$defs/host" },
    "profile": { "$ref": "#/$defs/profile" },
    "preflight": { "$ref": "#/$defs/preflight" },
    "compatibilityReceiptSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "assurance": { "$ref": "#/$defs/assurance" },
    "status": { "enum": ["selected", "unavailable"] },
    "failureClass": { "type": ["string", "null"], "enum": [null, "policy-drift", "host-unsupported", "evidence-stale", "preflight-failed", "profile-drift", "host-mode-unavailable"] },
    "observedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "dispatch": { "type": "object", "additionalProperties": false, "required": ["queueRevision", "candidateCommit", "candidateTree", "referenceSetSha256", "requestSha256"], "properties": { "queueRevision": { "type": "integer", "minimum": 0 }, "candidateCommit": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" }, "candidateTree": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" }, "referenceSetSha256": { "$ref": "#/$defs/digest" }, "requestSha256": { "$ref": "#/$defs/digest" } } },
    "toolchain": { "type": "object", "additionalProperties": false, "required": ["cliVersion", "cliSha256", "sandboxHelperSha256", "selectionSchemaSha256"], "properties": { "cliVersion": { "type": ["string", "null"] }, "cliSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }, "sandboxHelperSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }, "selectionSchemaSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" } } },
    "host": { "type": "object", "additionalProperties": false, "required": ["platformClass", "kernel", "filesystemClass", "bootIdSha256"], "properties": { "platformClass": { "enum": [null, "linux-native", "linux-wsl2", "macos-native", "windows-native"] }, "kernel": { "type": "object", "additionalProperties": false, "required": ["sysname", "release", "machine"], "properties": { "sysname": { "type": ["string", "null"] }, "release": { "type": ["string", "null"] }, "machine": { "type": ["string", "null"] } } }, "filesystemClass": { "enum": [null, "linux-native", "wsl2-native", "wsl2-9p", "macos-apfs", "windows-ntfs"] }, "bootIdSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" } } },
    "profile": { "type": "object", "additionalProperties": false, "required": ["id", "sha256", "base", "network", "writableRootClass", "scratchRootSha256"], "properties": { "id": { "const": "codex-critic-intermediate.v1" }, "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }, "base": { "const": ":read-only" }, "network": { "type": "object", "additionalProperties": false, "required": ["enabled"], "properties": { "enabled": { "const": true } } }, "writableRootClass": { "const": "coordinator-scratch-only" }, "scratchRootSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" } } },
    "preflight": { "type": "object", "additionalProperties": false, "required": ["receiptSha256", "eligibility", "terminalCode", "observedAt"], "properties": { "receiptSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }, "eligibility": { "enum": ["intermediate", "none"] }, "terminalCode": { "enum": ["eligible", "child-stdio-error", "profile-unavailable", "network-unavailable", "host-error"] }, "observedAt": { "type": ["string", "null"], "format": "date-time" } } },
    "assurance": { "type": "object", "additionalProperties": false, "required": ["class", "literal"], "properties": { "class": { "enum": ["sandbox-read-only-except-coordinator-scratch-network-open", "no-usable-review"] }, "literal": { "type": ["string", "null"] } } }
  }
}
