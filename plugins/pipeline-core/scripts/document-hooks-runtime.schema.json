{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline.document-hooks-runtime.v1",
  "title": "Generated regulated document hooks runtime projection",
  "description": "Closed public runtime projection derived from the exact repository Policy bytes. Class records and events are emitted in the deterministic order enforced by the handwritten validator.",
  "type": "object",
  "required": ["schema", "sourceSha256", "classes"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["pipeline.document-hooks-runtime.v1"]
    },
    "sourceSha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["classId", "bindingId", "mode", "events"],
        "additionalProperties": false,
        "properties": {
          "classId": {
            "type": "string",
            "enum": ["authorization", "operations", "emergency", "privacy"]
          },
          "bindingId": {
            "type": "string",
            "pattern": "^dh_[a-z2-7]{25}[aeimquy4]$"
          },
          "mode": {
            "type": "string",
            "enum": ["advisory", "mandatory"]
          },
          "events": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["design-impact", "verify", "close"]
            }
          }
        }
      }
    }
  }
}
