# .env.example — Agent-Pipeline environment overrides.
#
# Honest baseline: NO runtime environment variable is required to run the
# pipeline today. This file exists so the optional overrides below are
# discoverable, not because setup depends on it.
#
# Copy to `.env` (git-ignored) only if you need one of these overrides.

# --- Optional: security-scan tool path overrides ---------------------------
# The security-scan adapters (harness/scripts/security-adapters/*.mjs) look
# up gitleaks/osv-scanner/semgrep on PATH by default. Set these only if the
# binary lives somewhere non-standard on your machine.

# PIPELINE_GITLEAKS_PATH=
# PIPELINE_OSV_SCANNER_PATH=
# PIPELINE_SEMGREP_PATH=
